---
pagination:
  data: pacientes.list
  size: 1
  alias: paciente
permalink: "/pacientes/{{ paciente.name | slug }}/"
layout: "base.html"
---

<style>
    /* Estilos Generales */
    .main-content { padding-top: 100px; padding-bottom: 50px; background-color: #f8f9fa; }
    .story-card { background-color: #ffffff; border-radius: 15px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); overflow: hidden; }
    .story-image img { width: 100%; height: 100%; object-fit: cover; }
    .story-content { padding: 40px; }
    .story-content h1 { font-weight: 700; color: #333; }
    .story-content .lead { font-size: 1.1rem; color: #555; margin-bottom: 20px; }
    .key-info { list-style: none; padding: 0; }
    .key-info li { margin-bottom: 10px; display: flex; align-items: center; }
    .key-info i { color: #e63946; margin-right: 15px; font-size: 1.5rem; }

    /* --- INICIO: NUEVOS ESTILOS PARA EL FORMULARIO DE DONACIÓN --- */
    .donation-form {
        border: 1px solid #e9ecef;
        background-color: #fff;
        border-radius: 8px;
        padding: 2rem;
        margin-top: 2rem;
    }
    .donation-form h4 {
        font-weight: 600;
        text-align: center;
    }
    .donation-form .security-text {
        color: #6c757d;
        font-size: 0.9rem;
        text-align: center;
        margin-bottom: 1.5rem;
    }
    .donation-form .form-header {
        background-color: #a41d2a;
        color: white;
        text-align: center;
        padding: 0.75rem;
        font-weight: 500;
        border-radius: 4px;
        margin-bottom: 1.5rem;
    }
    .donation-form .amount-buttons .btn {
        flex: 1;
    }
    .donation-form .amount-buttons .btn.active {
        background-color: #6c757d;
        color: white;
        border-color: #6c757d;
    }
    .donation-form .btn-donate-final {
        background-color: #e63946;
        border-color: #e63946;
        font-weight: bold;
        padding: 0.75rem;
    }
    .payment-icons {
        text-align: center;
        margin-top: 1rem;
        opacity: 0.7;
    }
    /* --- FIN: NUEVOS ESTILOS --- */
</style>

<main class="main-content">
    <div class="container">
        <div class="story-card">
            <div class="row g-0">
                <div class="col-lg-6 story-image">
                    <img src="{{ paciente.image }}" alt="Foto de {{ paciente.name }}">
                </div>
                <div class="col-lg-6">
                    <div class="story-content">
                        <h1>Conoce a {{ paciente.name }}</h1>
                        <p class="lead">{{ paciente.story }}</p>
                        
                        <h4>Cómo lo Ayuda CADEP</h4>
                        <p>{{ paciente.help }}</p>

                        <ul class="key-info my-4">
                            <li><i class="bi bi-person-fill"></i><div><strong>Vive con:</strong> {{ paciente.living }}</div></li>
                            <li><i class="bi bi-clipboard2-pulse-fill"></i><div><strong>Diagnóstico:</strong> {{ paciente.disability }}</div></li>
                            <li><i class="bi bi-clock-history"></i><div><strong>Edad:</strong> {{ paciente.age }}</div></li>
                        </ul>

                        <div class="donation-form">
                            <h4>APOYA NUESTRA CAUSA</h4>
                            <p class="security-text"><i class="bi bi-lock-fill"></i> Tu donación se procesa de forma segura.</p>
                            
                            <div class="form-header">DONACIÓN ÚNICA</div>

                            <div class="d-flex gap-2 amount-buttons mb-3">
                                <button class="btn btn-outline-secondary" data-amount="10">$10</button>
                                <button class="btn btn-outline-secondary" data-amount="25">$25</button>
                                <button class="btn btn-outline-secondary active" data-amount="50">$50</button>
                                <button class="btn btn-outline-secondary" data-amount="100">$100</button>
                            </div>

                            <label class="form-label small">O ingresa otra cantidad</label>
                            <div class="input-group mb-3">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" id="custom-amount-input" placeholder="Valor" value="50">
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-danger btn-lg btn-donate-final">
                                    <i class="bi bi-heart-fill"></i> DONAR AHORA
                                </button>
                            </div>

                            <div class="payment-icons">
                                <p class="small text-muted">Aceptamos: VISA, Mastercard, PayPal, AMEX</p>
                            </div>
                        </div>
                        </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const donationForm = document.querySelector('.donation-form');
    if (donationForm) {
        const amountButtons = donationForm.querySelectorAll('.amount-buttons .btn');
        const customAmountInput = donationForm.querySelector('#custom-amount-input');

        // Función para manejar la selección de botones
        amountButtons.forEach(button => {
            button.addEventListener('click', () => {
                // Quitar 'active' de todos los botones
                amountButtons.forEach(btn => btn.classList.remove('active'));
                // Añadir 'active' al botón clickeado
                button.classList.add('active');
                // Actualizar el campo de texto con el monto
                customAmountInput.value = button.dataset.amount;
            });
        });

        // Función para cuando el usuario escribe una cantidad personalizada
        customAmountInput.addEventListener('input', () => {
            // Quitar 'active' de todos los botones predefinidos
            amountButtons.forEach(btn => btn.classList.remove('active'));
        });
    }
});
</script>