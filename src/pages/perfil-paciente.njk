---
pagination:
  data: pacientes.list
  size: 1
  alias: paciente
permalink: "/pacientes/{{ paciente.id }}/"
---

<h1>{{ paciente.fullName }}</h1>

<p><strong>Edad:</strong> {{ paciente.age }} años</p>
<p><strong>Género:</strong> {{ paciente.gender }}</p>

{% if paciente.area %}
  <p><strong>Área:</strong> {{ paciente.area.name }}</p>
{% endif %}

{% if paciente.branch %}
  <p><strong>Sucursal:</strong> {{ paciente.branch.name }}</p>
{% endif %}

{% if paciente.stats %}
  <p><strong>Donaciones:</strong> {{ paciente.stats.totalDonations }}</p>
  <p><strong>Monto recibido:</strong> Q{{ paciente.stats.totalAmountReceived }}</p>
{% endif %}

<a href="/pacientes/">← Volver al listado</a>
