---
layout: base.njk
pagination:
  data: pacientes.list
  size: 1
  alias: paciente
permalink: "perfil/{{ paciente.id }}/index.html"
---

<section class="paciente-detalle text-center">
  <div class="card mx-auto" style="max-width: 600px;">
    <h1 class="mt-3">{{ paciente.fullName }}</h1>

    {% if paciente.photoUrl %}
      <img src="http://localhost:3000{{ paciente.photoUrl }}" 
           alt="{{ paciente.fullName }}" 
           class="img-fluid rounded mb-3"
           style="max-height: 250px; object-fit: cover;">
    {% endif %}

    <p><strong>Edad:</strong> {{ paciente.age }}</p>
    <p><strong>Género:</strong> {{ paciente.gender }}</p>
    <p><strong>Área:</strong> {{ paciente.area.name }}</p>
    <p><strong>Sucursal:</strong> {{ paciente.branch.name }}</p>

    <div class="mt-4">
      <a href="/pacientes/" class="btn btn-primary">← Volver a Apadrinar</a>
      <a href="/" class="btn btn-secondary ms-2">🏠 Inicio</a>
    </div>
  </div>
</section>
