---
layout: base.njk
pagination:
  data: pacientes.list
  size: 1
  alias: paciente
permalink: "pacientes/{{ paciente.id }}/index.html"
---

<section class="paciente-detalle container my-5">
  <div class="row">
    <!-- Foto del paciente -->
    <div class="col-md-6">
      {% if paciente.photoUrl %}
        <img src="http://localhost:3000{{ paciente.photoUrl }}"
             alt="{{ paciente.fullName }}"
             class="img-fluid rounded shadow">
      {% else %}
        <img src="/assets/img/default-user.png"
             alt="Sin foto"
             class="img-fluid rounded shadow">
      {% endif %}
    </div>

    <!-- Información -->
    <div class="col-md-6">
      <h1>Conoce a {{ paciente.fullName }}</h1>
      <p><strong>Edad:</strong> {{ paciente.age }} años</p>
      <p><strong>Sexo:</strong> {{ paciente.gender }}</p>
      <p><strong>Área:</strong> {{ paciente.area.name }}</p>
      <p><strong>Sede:</strong> {{ paciente.branch.name }}</p>
      <p><strong>Departamento:</strong> {{ paciente.location.department.name }}</p>
      <p><strong>Municipio:</strong> {{ paciente.location.municipality.name }}</p>
      
      <!-- Extra -->
      <h4>Cómo lo ayuda CADEP</h4>
      <p>En CADEP recibe terapias y apoyo médico según el área de especialidad asignada.</p>

      <a href="/pacientes/" class="btn btn-primary mt-3">← Volver a la lista</a>
    </div>
  </div>
</section>
