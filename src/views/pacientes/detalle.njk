{% extends "layouts/base.njk" %}
{% block content %}
<section class="container py-5">
  <h1>Perfil del paciente</h1>
  <div class="card p-3 shadow-sm">
    <p><strong>ID:</strong> {{ paciente.id }}</p>
    <p><strong>Nombre:</strong> {{ paciente.fullName or paciente.nombre }}</p>
    {% if paciente.edad %}<p><strong>Edad:</strong> {{ paciente.edad }}</p>{% endif %}
    {% if paciente.diagnostico %}<p><strong>Diagnóstico:</strong> {{ paciente.diagnostico }}</p>{% endif %}
  </div>
</section>
{% endblock %}
